PORT=5000
# MongoDB — URI 경로 마지막이 DB 이름입니다. 비우면 로컬 mongodb://127.0.0.1:27017/shopping-malldemo
# Atlas: Network Access 에서 0.0.0.0/0 (또는 Heroku용) 허용 후 연결 문자열 사용
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/shopping-malldemo
#
# querySrv ECONNREFUSED 시: MONGODB_STANDARD_URI 에 Atlas "Standard"(mongodb:// 호스트 나열) 문자열
# MONGODB_STANDARD_URI=mongodb://cluster0-shard-00-00.xxxxx.mongodb.net:27017,.../shopping-malldemo?...
#
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
#
# 배포(Heroku 등): 프론트(Vercel) 출처만 허용 — 쉼표로 여러 URL 가능
# CLIENT_ORIGIN=https://your-app.vercel.app
#
# 로컬 + 프로덕션 동시 허용 예:
# CLIENT_ORIGIN=https://your-app.vercel.app,http://localhost:5173
#
# 로컬 DB 시드 (npm run db:reset) — 선택
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=your-secure-password
# SEED_ADMIN_NAME=Admin
#
