# --- API (프로덕션 필수) ---
# Vercel: client/vercel.json 의 build.env.VITE_API_URL 로도 주입 가능.
# 로컬 .env 에 넣거나, Vercel 대시보드 Environment Variables 에 설정.
# Heroku API 베이스 URL (끝 슬래시 없음, https).
# 비우면 빌드 결과는 /api 로 요청 → 정적 호스팅만으로는 API가 없으므로 프로덕션에서는 반드시 설정.
# 로컬 개발: 비워 두면 Vite 프록시(vite.config.ts 의 /api → 백엔드 포트) 사용.
# VITE_API_URL=https://vibecodingshoppingmall-be-05288f25e3d0.herokuapp.com

# --- Cloudinary (이미지 업로드) — 대시보드에서 클라이언트 업로드 허용 프리셋 사용 ---
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

# --- PortOne(아임포트) — 프로덕션 도메인을 콘솔에 등록 ---
# VITE_IAMPORT_IMP_CODE=impxxxxxxxx
